{
  "name": "pochi-rss",
  "version": "1.0.0",
  "description": "RSS Feed generator for websites without RSS support",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:ui": "cd admin-ui && npm run dev",
    "build:ui": "cd admin-ui && npm run build",
    "deploy": "npm run build:ui && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "rss",
    "scraping",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.3.4",
    "cheerio": "^1.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "^4.20240129.0",
    "@vitest/ui": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4",
    "wrangler": "^3.78.12"
  }
}
